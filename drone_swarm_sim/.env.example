# Qdrant Configuration - Using your existing container
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_COLLECTION=drone_swarm_faces

# Optional: If you want to access makai collection too
MAKAI_COLLECTION=makai

# Drone Swarm Configuration
NUM_DRONES=5
SIMULATION_MODE=true
WORLD_SIZE=1000,1000

# LLM Configuration
LLM_MODE=mock  # Use 'mock' for simulation, 'edge' for real LLM